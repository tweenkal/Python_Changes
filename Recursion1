def resolve_issue(level, max_level):
    print(f"Level {level} support is troubleshooting...")

    # Simulate whether this level fixes the issue
    issue_fixed = False  # Change this logic as needed

    if issue_fixed:
        print(f"Issue resolved at Level {level} support ✅")
        return True

    # Base case: no higher level available
    if level == max_level:
        print(f"Level {level} could not resolve the issue.")
        print("No higher support level available. Issue remains unresolved ❌")
        return False

    # Recursive case: escalate to next level
    print(f"Escalating issue from Level {level} to Level {level + 1}...\n")
    return resolve_issue(level + 1, max_level)


# Start escalation from Level 1 up to Level 3
resolve_issue(1, 3)
