<odoo>

    <!-- Tree view: shows all book categories in list form -->
    <record id="view_book_category_tree" model="ir.ui.view">
        <field name="name">book.category.tree</field> <!-- view technical name -->
        <field name="model">book.category</field> <!-- linked model -->
        <field name="arch" type="xml">
            <tree string="Categories">
                <field name="category_name"/> <!-- column shown in list -->
            </tree>
        </field>
    </record>

    <!-- Form view: used to create and edit a single category -->
    <record id="view_book_category_form" model="ir.ui.view">
        <field name="name">book.category.form</field> <!-- view technical name -->
        <field name="model">book.category</field> <!-- linked model -->
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <group>
                        <field name="category_name"/> <!-- input field -->
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action: connects model with tree and form views -->
    <record id="action_book_category" model="ir.actions.act_window">
        <field name="name">Categories</field> <!-- action label -->
        <field name="res_model">book.category</field> <!-- model to open -->
        <field name="view_mode">tree,form</field> <!-- views sequence -->
    </record>

</odoo>
