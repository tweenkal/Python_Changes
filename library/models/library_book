from odoo import models, fields

class LibraryBook(models.Model):
    _name = 'library.book'
    _description = 'Library Book'

    name = fields.Char(string="Book Title", required=True)

    category_id = fields.Many2one(
        'book.category',
        string="Category"
    )

    edition_ids = fields.Many2many(
        'book.edition',
        string="Editions"
    )
