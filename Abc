from odoo import models, api, _
from odoo.exceptions import ValidationError

class LibraryBook(models.Model):
    _name = 'library.book'

    def _validate_book_data(self, vals, record=None):
        """Common validation for create and write."""

        # Category validation
        if ('category_id' in vals and not vals.get('category_id')) or (not record and not vals.get('category_id')):
            raise ValidationError(_("Category must be selected."))

        # Edition validation (only for create)
        if not record and not vals.get('edition_ids'):
            raise ValidationError(_("At least one edition is required."))

        # Prevent edition modification in write
        if record and 'edition_ids' in vals:
            raise ValidationError(_("Selected editions cannot be modified directly."))

        # Pages validation
        pages = vals.get('pages', record.pages if record else 0)
        if pages <= 0:
            raise ValidationError(_("Pages must be greater than 0."))

        # Price validation
        price = vals.get('price', record.price if record else 0)
        if price <= 0:
            raise ValidationError(_("Price must be greater than 0."))

    @api.model_create_multi
    def create(self, vals_list):
        for vals in vals_list:
            self._validate_book_data(vals)
        return super().create(vals_list)

    def write(self, vals):
        for record in self:
            self._validate_book_data(vals, record)
        return super().write(vals)
