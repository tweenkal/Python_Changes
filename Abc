<odoo>
    <record id="auto_action_reservation_confirmed" model="base.automation">
        
        <!-- Name -->
        <field name="name">Reservation Confirmation Message</field>

        <!-- Model -->
        <field name="model_id" ref="model_book_reservation"/>

        <!-- Trigger: On Save -->
        <field name="trigger">on_write</field>

        <!-- Trigger ONLY when state field changes -->
        <field name="trigger_field_ids" eval="[(4, ref('ak_library_search_domain.field_book_reservation__state'))]"/>

        <!-- Condition -->
        <field name="filter_domain">[('state','=','reserved')]</field>

        <!-- Action Type -->
        <field name="state">code</field>

        <!-- Python Code -->
        <field name="code">
if record.state == 'reserved':
    record.message_post(
        body=f"""
        &lt;b&gt;Reservation Confirmed&lt;/b&gt;&lt;br/&gt;
        Customer: {record.partner_id.name}&lt;br/&gt;
        Pickup Before: {record.expected_pickup_date}
        """
    )
        </field>

        <!-- Active -->
        <field name="active">True</field>

    </record>
</odoo>
