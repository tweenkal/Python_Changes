from odoo import models, fields, api, _
from datetime import timedelta

class LibraryBook(models.Model):
    _name = 'library.book'
    _description = 'Library Book'
    _inherit = ['mail.thread', 'mail.activity.mixin']

    name = fields.Char(string='Book Name', required=True)
    author_id = fields.Many2one('res.partner', string='Author', required=True)

    _sql_constraints = [
        ('unique_name_author', 'unique(name, author_id)', 'This author already has a book with the same name.')
    ]

    @api.model_create_multi
    def create(self, vals_list):
        records = super().create(vals_list)
        for record in records:
            # Log Note
            record.message_post(body=_("Book %s has been created by %s at %s") % (
                record.name, self.env.user.name, fields.Datetime.now()
            ))

            if record.author_id:
                # Notification to Author
                record.message_post(
                    body=_("Your book %s is released by %s. Please review.") % (record.name, self.env.user.name),
                    partner_ids=[record.author_id.id]
                )

                # Schedule Activity (Removed [:1])
                record.activity_schedule(
                    'mail.mail_activity_data_todo',
                    summary=_('Review your release %s') % record.name,
                    note=_('Please review the book. It is ready for release.'),
                    user_id=record.author_id.user_id.id or self.env.user.id,
                    date_deadline=fields.Date.today() + timedelta(days=2)
                )
        return records
