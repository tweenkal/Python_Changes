<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <!-- Main menu for Library module -->
    <menuitem id="menu_library_root"
              name="Library Management"
              sequence="10"/>

    <!-- Menu to open Books screen -->
    <menuitem id="menu_library_book"
              name="Books"
              parent="menu_library_root"
              action="action_library_book"/>

    <!-- Menu to open Categories screen -->
    <menuitem id="menu_library_category"
              name="Category"
              parent="menu_library_root"
              action="action_book_category"/>

    <menuitem id="menu_author"
              name="Authors"
              parent="menu_library_root"
              action="action_author_author"/>

    <!-- Configuration Menu-->
    <menuitem id="menu_library_config"
              name="Configuration"
              parent="menu_library_root"
              sequence="100"/>

    <!-- Book Edition Menu-->
    <menuitem id="menu_book_edition"
              name="Edition"
              parent="menu_library_config"
              action="action_book_edition"/>

</odoo>
