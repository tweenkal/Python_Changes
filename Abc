def action_reservation_analysis(self):
    """ Open the reserved book count inside graph view without domain key. """
    return {
        'name': _('Reservation Analysis'),
        'type': 'ir.actions.act_window',
        'res_model': 'book.reservation',
        'view_mode': 'graph',
        'target': 'current'
    }

def _read_group(self, domain, groupby=(), aggregates=(), having=(), offset=0, limit=None, order=None):
    """ Injecting 'reserved' state domain inside the read_group method. """
    
    # Domain check karke usme state filter add kar diya
    domain = (domain or []) + [('state', '=', 'reserved')]
    
    return super()._read_group(
        domain=domain, 
        groupby=groupby, 
        having=having, 
        offset=offset, 
        limit=limit, 
        order=order, 
        aggregates=aggregates
    )
