<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_author_layout">
        <div class="header" style="width:100%; margin-bottom:20px;">
            <div style="float:left; width:50%;">
                <img t-if="company.id"
                     t-att-src="'/web/image/res.company/%s/logo' % company.id"
                     style="height:60px;"/>
            </div>
            <div style="float:right; width:50%; text-align:right; font-size:13px;">
                <div>
                    <span t-esc="company.partner_id.street"/>
                    <span t-esc="company.partner_id.city"/>
                    <span t-esc="company.partner_id.country_id.name"/>
                </div>
                <div><span t-esc="company.email"/></div>
                <div><span t-esc="company.phone"/></div>
            </div>
        </div>

        <t t-raw="0"/>

        <div class="footer" style="margin-top:20px; font-size:12px;">
            <div style="border-top:1px solid #000; margin-bottom:8px;"></div>

            <div style="width:100%;">
                <div style="float:left;">
                    <img t-if="company.id"
                         t-att-src="'/web/image/res.company/%s/logo' % company.id"
                         style="height:35px;"/>
                </div>

                <div style="float:right;">
                    Page <span class="page"/>/<span class="topage"/>
                </div>
            </div>
        </div>
    </template>

    <template id="report_author_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="env.company"/>
                <t t-call="ak_library_search_domain.report_author_layout">
                    <div class="page" style="padding:20px 30px;">
                        <div style="margin-top:30px; margin-bottom:40px; font-size:15px;">
                            <span t-esc="doc.name"/><br/><br/>
                            <span t-esc="doc.gender"/><br/><br/>
                            <span t-esc="doc.email"/><br/><br/>
                            <span t-esc="doc.phone"/><br/><br/>
                        </div>
                        <table width="100%"
                           style="border-collapse:collapse; margin-top:50px; font-size:14px;">
                            <thead>
                                <tr style="background-color:#F5F5F5;">
                                    <th style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px; text-align:left;">
                                        Book Name
                                    </th>
                                    <th style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px; text-align:left;">
                                        ISBN
                                    </th>
                                    <th style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px; text-align:left;">
                                        Publish Date
                                    </th>
                                    <th style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px; text-align:right;">
                                        Pages
                                    </th>
                                    <th style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px; text-align:right;">
                                        Price
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.book_ids" t-as="book">

                                    <td style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px;">
                                        <span t-esc="book.book_id.name"/>
                                    </td>

                                    <td style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px;">
                                        <span t-esc="book.isbn"/>
                                    </td>

                                    <td style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px;">
                                        <span t-esc="book.publication_date"/>
                                    </td>

                                    <td style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px;
                                        text-align:right;">
                                        <span t-esc="book.pages"/>
                                    </td>

                                    <td style="border-top:1px solid #dcdcdc;
                                        border-bottom:1px solid #dcdcdc; padding:8px;
                                        text-align:right;">
                                        <span t-esc="book.price"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
