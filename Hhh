# -*- coding: utf-8 -*-

from odoo import fields, models, _
from odoo.exceptions import ValidationError


class BookOrderWizard(models.TransientModel):
    _name = 'book.order.wizard'
    _description = 'Library Book Order Wizard'

    sale_order_id = fields.Many2one(
        comodel_name='sale.order',
        string='Sale Order'
    )

    line_ids = fields.One2many(
        comodel_name='book.order.wizard.line',
        inverse_name='wizard_id',
        string='Lines'
    )

    def action_book_order_wizard(self):
        self.ensure_one()

        for line in self.line_ids:

            if not line.product_id or line.quantity <= 0:
                raise ValidationError(
                    _("Each line must have a product selected and Quantity "
                      "must be greater than zero : %s") %
                    (line.product_id.display_name or "No Product")
                )

            found = False

            # ✅ FOR LOOP (no singleton issue)
            for so_line in self.sale_order_id.order_line.filtered(
                lambda l: l.product_id.id == line.product_id.id
            ):

                found = True

                # ✅ MERGE
                so_line.product_uom_qty += line.quantity

                break  # ek hi line update karni hai

            # ✅ ELSE → CREATE (edit case me new bhi ho sakta hai)
            if not found:
                self.env['sale.order.line'].create({
                    'order_id': self.sale_order_id.id,
                    'product_id': line.product_id.id,
                    'product_uom_qty': line.quantity,
                })

        self.sale_order_id.has_book_added = True
        return {'type': 'ir.actions.act_window_close'}
