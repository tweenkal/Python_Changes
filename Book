<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_inherit_custom"
              inherit_id="account.report_invoice_document">

        <!-- ========================================= -->
        <!-- 1. HEADER ALIGNMENT (LOGO + CLIENT INFO) -->
        <!-- ========================================= -->

        <xpath expr="//div[contains(@class,'row')][1]" position="replace">
            <div class="row">

                <!-- LEFT SIDE (LOGO + INVOICE INFO) -->
                <div class="col-6">
                    <img t-if="company.logo"
                         t-att-src="image_data_uri(company.logo)"
                         style="max-height:80px;"/>

                    <!-- Invoice Details BELOW LOGO -->
                    <div style="margin-top:10px;">
                        <p>
                            <strong>Invoice Reference:</strong>
                            <span t-field="doc.name"/>
                        </p>
                        <p>
                            <strong>Invoice Date:</strong>
                            <span t-field="doc.invoice_date"/>
                        </p>
                        <p>
                            <strong>Payment Term:</strong>
                            <span t-field="doc.invoice_payment_term_id.name"/>
                        </p>
                    </div>
                </div>

                <!-- RIGHT SIDE (CLIENT INFO BOLD) -->
                <div class="col-6" style="text-align:right;">
                    <strong>
                        <span t-field="doc.partner_id.name"/><br/>
                        <span t-field="doc.partner_id.street"/><br/>
                        <span t-field="doc.partner_id.city"/>
                        <t t-if="doc.partner_id.state_id">
                            , <span t-field="doc.partner_id.state_id.name"/>
                        </t><br/>
                        <span t-field="doc.partner_id.country_id.name"/>
                    </strong>
                </div>

            </div>
        </xpath>


        <!-- ========================================= -->
        <!-- 2. REMOVE OLD INVOICE INFO (IF EXISTS) -->
        <!-- ========================================= -->

        <xpath expr="//p[contains(text(),'Invoice Date')]" position="remove"/>
        <xpath expr="//p[contains(text(),'Invoice Reference')]" position="remove"/>
        <xpath expr="//p[contains(text(),'Payment Term')]" position="remove"/>


        <!-- ========================================= -->
        <!-- 3. REMOVE OLD BANK ACCOUNT LINE -->
        <!-- ========================================= -->

        <xpath expr="//p[contains(text(),'account')]" position="remove"/>


        <!-- ========================================= -->
        <!-- 4. ADD BANK ACCOUNT BELOW AMOUNT DUE -->
        <!-- ========================================= -->

        <xpath expr="//tr[td//span[@t-field='doc.amount_residual']]" position="after">
            <tr>
                <td colspan="2" style="padding-top:10px;">
                    <strong>Bank Account No:</strong>
                    <span t-field="doc.partner_bank_id.acc_number"/>
                </td>
            </tr>
        </xpath>

    </template>

</odoo>
