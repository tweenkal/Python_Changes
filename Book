# -*- coding: utf-8 -*-

from odoo import api, models, _
from odoo.exceptions import ValidationError


class LibraryBook(models.Model):
    _inherit = 'library.book'

    @api.model
    def default_get(self, fields_list):
        """
            Set default values for price and pages when creating a new book.
            Args:
                fields_list : List of requested field names.
            Returns:
                dict: Default values for the requested fields.
        """
        book = super().default_get(fields_list)
        if 'price' in fields_list and not book.get('price'):
            book['price'] = 500.0
        if 'pages' in fields_list and not book.get('pages'):
            book['pages'] = 100

        return book

    def _validate_book(self, vals):
        """
        Common validation method for library book records.
        Handles both create and write operations without extra parameters.
        """
        # Category validation
        if 'category_id' in vals and not vals.get('category_id'):
            raise ValidationError(_("Category must be selected."))

        # Pages and price validation
        pages = vals.get('pages', getattr(self, 'pages', 0))
        price = vals.get('price', getattr(self, 'price', 0))
        if pages <= 0:
            raise ValidationError(_("Pages must be greater than 0."))
        if price <= 0:
            raise ValidationError(_("Price must be greater than 0."))

        if 'edition_ids' in vals:
            if not self:  # Creating new record (self is empty)
                if not vals.get('edition_ids'):
                    raise ValidationError(_('At least one edition is required.'))
            else:  # Updating existing record
                raise ValidationError(_('Selected editions cannot be modified directly.'))

    @api.model_create_multi
    def create(self, vals_list):
        """
            Create new library book records with validation.
            Args:
                vals_list : List of field values for each book.
            Returns:
                recordset: Created library.book records otherwise raises
                ValidationError.
        """
        for vals in vals_list:
            self._validate_book(vals)
        return super().create(vals_list)

    def write(self, vals):
        """
            Update library book records with validation.
            Args:
                vals : Field values to update.
            Returns:
                bool: True if update is successful otherwise raises
                ValidationError.
        """
        for record in self:
            record._validate_book(vals)
        return super().write(vals)
    
    def unlink(self):
        """
            Delete library book records and related author.book entries.
            Returns:
                bool: True if deletion is successful.
        """
        for book_record in self:
            author_book = self.env['author.book']

            author_record = author_book.search(
                [('book_id', '=', book_record.id)])
            author_record.unlink()

        return super().unlink()

    def copy(self, default=None):
        """
            Duplicate a library book record.
            Args:
                default : Values to override in the copy.
            Returns:
                recordset: The duplicated library.book record.
        """
        default = dict(default or {})
        default['name'] = self.name + "(copy)"
        return super().copy(default)
