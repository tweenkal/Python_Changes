<record id="group_library_staff" model="res.groups">
    <field name="name">Library Staff</field>
</record>

<record id="group_librarian" model="res.groups">
    <field name="name">Librarian</field>
    <field name="implied_ids" eval="[(4, ref('group_library_staff'))]"/>
</record>

<record id="group_library_manager" model="res.groups">
    <field name="name">Library Manager</field>
    <field name="implied_ids" eval="[(4, ref('group_librarian'))]"/>
</record>
