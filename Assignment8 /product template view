<odoo>
    <record id="product_template_form_inherit_books" model="ir.ui.view">
        <field name="name">product.template.form.books</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <div name="button_box" position="inside">
                <button name="action_view_books"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-book"
                        attrs="{'invisible':[('book_id','=',False)]}">
                    <field name="book_count" widget="statinfo" string="Books"/>
                </button>
            </div>

        </field>
    </record>
</odoo>
