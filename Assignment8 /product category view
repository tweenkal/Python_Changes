<odoo>
    <record id="view_product_category_form_buttons" model="ir.ui.view">
        <field name="name">product.category.form.buttons</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <header>
                <button name="action_open_book_category"
                        string="Book Category"
                        type="object"
                        attrs="{'invisible':[('book_categ_id','=',False)]}"
                        class="btn-secondary"/>
            </header>
        </field>
    </record>
</odoo>
