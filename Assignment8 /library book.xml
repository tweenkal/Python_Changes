3.1 Add Button in Form Header
<button name="action_create_product"
        type="object"
        string="Create Product"
        class="btn-primary"
        attrs="{'invisible': [('product_count','>',0)]}"/>

3.2 Add Smart Button
<button name="action_view_product"
        type="object"
        class="oe_stat_button"
        icon="fa-cube"
        attrs="{'invisible': [('product_count','=',0)]}">
    <field name="product_count" widget="statinfo" string="Product"/>
</button>
