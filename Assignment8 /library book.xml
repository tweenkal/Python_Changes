<odoo>
    <record id="view_library_book_form_buttons" model="ir.ui.view">
        <field name="name">library.book.form.buttons</field>
        <field name="model">library.book</field>
        <field name="inherit_id" ref="ak_library_management_orm.library_book_form"/>
        <field name="arch" type="xml">
            <header>
                <button name="action_create_product"
                        string="Create Product"
                        type="object"
                        attrs="{'invisible': [('product_created','=',True)]}"
                        class="btn-primary"/>
                <button name="action_open_product"
                        string="Product"
                        type="object"
                        attrs="{'invisible': [('product_created','=',False)]}"
                        class="btn-secondary"/>
            </header>
        </field>
    </record>
</odoo>
