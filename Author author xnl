<odoo>
    <record id="view_author_tree" model="ir.ui.view">
        <field name="name">author.author.tree</field>
        <field name="model">author.author</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="dob_date"/>
                <field name="gender"/>
            </tree>
        </field>
    </record>

    <record id="view_author_form" model="ir.ui.view">
        <field name="name">author.author.form</field>
        <field name="model">author.author</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="dob_date"/>
                        <field name="gender"/>
                        <field name="nationality"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="social_profile"/>
                    </group>

                    <notebook>
                        <page string="Books">
                            <field name="book_ids">
                                <tree editable="bottom">
                                    <field name="book_id"/>
                                    <field name="isbn"/>
                                    <field name="price"/>
                                    <field name="publication_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_author" model="ir.actions.act_window">
        <field name="name">Author</field>
        <field name="res_model">author.author</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
