<odoo>

    <record id="sale_order_form_inherit_library" model="ir.ui.view">
        <field name="name">sale.order.form.library.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Modify Confirm Button -->
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="attrs">
                    {'invisible': [('approval_required','=',True),('approval_done','=',False)]}
                </attribute>
            </xpath>

            <!-- Approve Button -->
            <xpath expr="//header" position="inside">

                <button name="action_manager_approve"
                        type="object"
                        string="Approve"
                        class="btn-primary"
                        attrs="{'invisible':[('approval_required','=',False)]}"
                        groups="base.group_user"/>

                <button name="action_manager_reject"
                        type="object"
                        string="Reject"
                        class="btn-danger"
                        attrs="{'invisible':[('approval_required','=',False)]}"
                        groups="base.group_user"/>

            </xpath>

        </field>
    </record>

</odoo>
