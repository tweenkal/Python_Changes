<record id="product_template_form_inherit_book" model="ir.ui.view">
    <field name="name">product.template.form.inherit.book</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/> <!-- Default Odoo product template form -->
    <field name="arch" type="xml">
        <!-- Locate Invoice Policy field -->
        <xpath expr="//field[@name='invoice_policy']" position="after">
            <field name="is_book_product" widget="boolean" string="Is Book Product"/>
            <field name="book_id"/>
        </xpath>
    </field>
</record>
