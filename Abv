<odoo>
    <!-- 5. Reservation Graph View -->
    <record id="view_book_reservation_graph" model="ir.ui.view">
        <field name="name">book.reservation.graph</field>
        <field name="model">book.reservation</field>
        <field name="arch" type="xml">
            <graph string="Reservation Analysis" type="bar">
                <field name="book_id" type="row"/>
            </graph>
        </field>
    </record>

    <!-- Reservation Tree View -->
    <record id="view_book_reservation_tree" model="ir.ui.view">
        <field name="name">book.reservation.tree</field>
        <field name="model">book.reservation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="customer_id"/>
                <field name="book_id"/>
                <field name="reservation_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Reservation Form View with Analysis Button -->
    <record id="view_book_reservation_form" model="ir.ui.view">
        <field name="name">book.reservation.form</field>
        <field name="model">book.reservation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- 5. Analysis Button in Header -->
                    <button name="action_reservation_analysis" string="Reservation Analysis" 
                            type="object" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,reserved,picked_up"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="book_id"/>
                        </group>
                        <group>
                            <field name="reservation_date"/>
                            <field name="expected_pickup_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 6. Smart Button in Author Form View -->
    <record id="view_author_form_inherit" model="ir.ui.view">
        <field name="name">author.author.form.inherit</field>
        <field name="model">author.author</field>
        <field name="inherit_id" ref="ak_library_management_orm.view_author_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_reservations_smart_button" type="object" 
                        class="oe_stat_button" icon="fa-book">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Reservations</span>
                    </div>
                </button>
            </div>
        </field>
    </record>

    <!-- Action for the Reservation Menu -->
    <record id="action_book_reservation" model="ir.actions.act_window">
        <field name="name">Book Reservations</field>
        <field name="res_model">book.reservation</field>
        <field name="view_mode">tree,form,graph</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_book_reservation" name="Reservations" 
              parent="ak_library_management_orm.menu_root" 
              action="action_book_reservation"/>
</odoo>
