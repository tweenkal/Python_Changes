<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- 🔹 External Layout Inherit -->
    <template id="external_layout_inherit_invoice"
              inherit_id="web.external_layout_standard">

        <!-- ✅ Replace header address block -->
        <xpath expr="//div[@class='row']" position="after">

            <div class="row mt-3 mb-3">

                <!-- LEFT SIDE (Invoice Details - Logo के नीचे) -->
                <div class="col-6">

                    <div class="mb-1">
                        <strong>Invoice Reference:</strong>
                        <span t-field="o.name"/>
                    </div>

                    <div class="mb-1">
                        <strong>Invoice Date:</strong>
                        <span t-field="o.invoice_date"/>
                    </div>

                    <div class="mb-1">
                        <strong>Payment Term:</strong>
                        <span t-field="o.invoice_payment_term_id.name"/>
                    </div>

                </div>

                <!-- RIGHT SIDE (Client Address - Bold) -->
                <div class="col-6 text-end">
                    <strong>
                        <address t-field="o.partner_id"
                                 t-options='{"widget": "contact", "fields": ["name","address"], "no_marker": True}'/>
                    </strong>
                </div>

            </div>

        </xpath>

    </template>


    <!-- 🔹 Invoice Report Adjustments -->
    <template id="report_invoice_document_inherit"
              inherit_id="account.report_invoice_document">

        <!-- ❌ Hide old info block -->
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>

        <!-- ✅ Bank details -->
        <xpath expr="//div[@id='total']" position="after">
            <div class="mt-3 text-end">
                <strong>Bank Account No.:</strong>
                <span t-field="o.partner_bank_id"/>
            </div>
        </xpath>

    </template>

</odoo>
