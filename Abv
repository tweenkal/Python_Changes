<odoo>

    <template id="custom_external_layout" inherit_id="web.external_layout">

        <!-- HEADER -->
        <xpath expr="//div[@class='header']" position="replace">
            <div class="header" style="border-bottom:1px solid #000; padding:10px;">
                <div class="row">
                    
                    <div class="col-6">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height:60px;"/>
                    </div>

                    <div class="col-6 text-end">
                        <div t-esc="company.partner_id.contact_address"/>
                        <div t-esc="company.email"/>
                        <div t-esc="company.phone"/>
                    </div>

                </div>
            </div>
        </xpath>

        <!-- FOOTER -->
        <xpath expr="//div[@class='footer']" position="replace">
            <div class="footer" style="border-top:1px solid #000; padding:10px;">
                <div class="row">

                    <div class="col-6">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height:40px;"/>
                    </div>

                    <div class="col-6 text-end">
                        Page: <span class="page"/> / <span class="topage"/>
                    </div>

                </div>
            </div>
        </xpath>

    </template>

</odoo>
