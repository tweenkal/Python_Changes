class BankAccount:
    """Represents a basic bank account with deposit, withdraw and balance display."""

    def __init__(self, account_number, account_holder, initial_balance=0):
        self.account_number = account_number
        self.account_holder = account_holder
        self._balance = initial_balance

    def deposite(self, amount):
        if amount > 0:
            self._balance += amount
            print(f"Deposit amount is = {amount}")
        else:
            print("Deposit amount must be positive")

    def withdraw(self, amount, overdraft_limit=0):
        """Withdraw with optional overdraft support"""

        if amount <= 0:
            print("Withdraw amount must be positive")
            return False

        if amount <= self._balance:
            self._balance -= amount
            print(f"Withdraw amount is = {amount}")
            return True

        # Overdraft logic
        if overdraft_limit > 0:
            print("Insufficient balance.")
            choice = input("Do you want to use overdraft? (y/n): ")
            if choice.lower() == 'y':
                if amount <= self._balance + overdraft_limit:
                    self._balance -= amount
                    print(f"Withdraw amount = {amount}")
                    print(f"Current balance = {self._balance} (Overdraft used)")
                    return True
                else:
                    print("Overdraft limit exceeded! Withdraw denied.")
                    return False

        print("Insufficient fund")
        return False

    def display_balance(self):
        print("\n--- Account Details ---")
        print(f"Account Holder: {self.account_holder}")
        print(f"Account Number: {self.account_number}")
        print(f"Balance: {self._balance}")


class SavingsAccount(BankAccount):
    """Savings account with interest"""

    def __init__(self, account_number, account_holder, initial_balance=0, interest_rate=0):
        super().__init__(account_number, account_holder, initial_balance)
        self.interest_rate = interest_rate

    def calculate_interest(self):
        interest = self._balance * self.interest_rate
        print(f"Calculated interest: {interest}")
        return interest

    def apply_interest(self):
        interest = self.calculate_interest()
        self.deposite(interest)
        print("Interest applied.")


class CurrentAccount(BankAccount):
    """Current account with overdraft facility"""

    def __init__(self, account_number, account_holder, initial_balance=0, overdraft_limit=0):
        super().__init__(account_number, account_holder, initial_balance)
        self.overdraft_limit = overdraft_limit

    def withdraw(self, amount):
        return super().withdraw(amount, self.overdraft_limit)


# ---------------- SAVINGS ACCOUNT OPERATIONS ---------------- #

def savings_account_operations():
    print("------- User input for saving account --------\n")

    account_number = input("Enter Saving account number = ")
    account_holder = input("Enter account holder name = ")
    initial_balance = float(input("Enter initial balance for savings = "))
    interest_rate = float(input("Enter interest rate (%) = ")) / 100

    savings = SavingsAccount(account_number, account_holder, initial_balance, interest_rate)

    while True:
        print("\n------------ Saving Account Menu ------------")
        print("1. Deposit")
        print("2. Withdraw")
        print("3. Apply Interest")
        print("4. Display Balance")
        print("5. Exit")

        option = input("Select option = ")

        if option == "1":
            amount = float(input("Enter amount to deposit: "))
            savings.deposite(amount)

        elif option == "2":
            amount = float(input("Enter amount to withdraw: "))
            savings.withdraw(amount)

        elif option == "3":
            rate = float(input("Enter new interest rate (%): "))
            savings.interest_rate = rate / 100
            savings.apply_interest()

        elif option == "4":
            savings.display_balance()

        elif option == "5":
            print("Exiting savings account operations.")
            break

        else:
            print("Invalid option.")

    return savings


