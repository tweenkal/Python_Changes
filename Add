<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_custom"
              inherit_id="account.report_invoice_document">

        <!-- ========================= -->
        <!-- 1. CUSTOMER NAME + ADDRESS BOLD -->
        <!-- ========================= -->
        <xpath expr="//t[@t-set='address']" position="inside">
            <div>
                <strong t-field="o.partner_id.name"/>
            </div>
        </xpath>

        <!-- ========================= -->
        <!-- 2. INVOICE DETAILS (TOP ALIGN) -->
        <!-- ========================= -->
        <xpath expr="//div[contains(@class,'mt32 mb32')]" position="inside">
            <div>
                <p>
                    <strong>Invoice Reference:</strong>
                    <span t-field="o.name"/>
                </p>

                <p>
                    <strong>Invoice Date:</strong>
                    <span t-field="o.invoice_date"/>
                </p>

                <p>
                    <strong>Payment Term:</strong>
                    <span t-field="o.invoice_payment_term_id.name"/>
                </p>
            </div>
        </xpath>

        <!-- ========================= -->
        <!-- 3. BANK ACCOUNT AFTER TOTAL -->
        <!-- ========================= -->
        <xpath expr="//div[@id='total']" position="after">
            <div>
                <p>
                    <strong>Bank Account No:</strong>
                    <span t-field="o.partner_bank_id.acc_number"/>
                </p>
            </div>
        </xpath>

    </template>

</odoo>
