<odoo>
    <record id="view_library_book_form_inherit" model="ir.ui.view">
        <field name="name">library.book.form.inherit.author</field>
        <field name="model">library.book</field>
        <field name="inherit_id" ref="library.view_library_book_form"/>
        <field name="arch" type="xml">
            <field name="author_id" position="attributes">
                <attribute name="domain">[('status','=','active')]</attribute>
                <attribute name="options">{'no_create': True}</attribute>
            </field>
        </field>
    </record>

    <!-- Enable search by name and reference -->
    <record id="library_author_autocomplete" model="ir.actions.act_window.view">
        <field name="name">author_autocomplete</field>
        <field name="model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_name': 1}</field>
    </record>
</odoo>
