from odoo import models, fields

class AuthorBook(models.Model):
    _name = 'author.book'
    _description = 'Author Book'

    author_id = fields.Many2one(
        'author.author',
        required=True,
        ondelete='cascade'
    )

    book_id = fields.Many2one(
        'library.book',
        required=True,
        ondelete='cascade'
    )

    isbn = fields.Char()
    publication_date = fields.Date()
    price = fields.Float()
