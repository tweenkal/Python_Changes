from odoo import models, fields, api

class LibraryBook(models.Model):
    _name = 'library.book'
    _description = 'Library Book'

    name = fields.Char(required=True)
    isbn = fields.Char()
    publication_date = fields.Date()
    price = fields.Float()

    author_id = fields.Many2one(
        'author.author',
        string='Author'
    )

    author_book_id = fields.Many2one(
        'author.book',
        string='Author Book Link',
        compute='_compute_author_book',
        store=True
    )
